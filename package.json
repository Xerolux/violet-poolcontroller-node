{
  "name": "violet-poolcontroller",
  "version": "0.1.0",
  "description": "Asynchronous TypeScript client for the Violet Pool Controller HTTP API.",
  "license": "AGPL-3.0-or-later",
  "author": "Basti (Xerolux) <git@xerolux.de>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "clean": "node --run clean:dist",
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "parity:check": "node scripts/check-upstream-parity.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xerolux/violet-poolcontroller-node.git"
  },
  "homepage": "https://github.com/Xerolux/violet-poolcontroller-node#readme",
  "bugs": {
    "url": "https://github.com/Xerolux/violet-poolcontroller-node/issues"
  },
  "keywords": [
    "pool",
    "violet",
    "controller",
    "typescript",
    "home-automation",
    "async"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "dependencies": {
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
